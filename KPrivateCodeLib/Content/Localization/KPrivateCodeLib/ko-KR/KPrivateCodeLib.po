msgctxt "ST_KPrivateCodeLib,Widget_SettingPopup.RichTextBlock.Text"
msgid "<LightGrey12Reg>Thanks for using </><Orange12Reg>KMods</>"
msgstr "<Orange12Reg>KMods</><LightGrey12Reg>를 사용해 주셔서 감사합니다</>"

msgid "<LightGrey12Reg>we want you to be able to decide whether and </><Orange12Reg>which advertising you want to see!</>\\r\\n<LightGrey12Reg>You can change this at any time in the </><Orange12Reg>KPrivateLib Mod Configs.</>\\r\\n\\r\\n<Orange12Reg>This popup will only appear once</>"
msgstr ""
"<Orange12Reg>우리는 사용자가</><LightGrey12Reg>어떤 광고를 볼 지 직접 결정할 수 있도록 하고 있습니다.</>\\r\\n<Orange12Reg>KPrivateLib 모드 설정에서</><LightGrey12Reg>언제든지 변경할 수 있습니다.</>\\r\\n\\r\\n<Orange12Reg>이 팝업창은 한 번만 표시됩니다.</>\n"
""

