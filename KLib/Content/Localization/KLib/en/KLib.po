msgctxt "ST_Klib,Build_ChemReactor.Build_ChemReactor_C.mDescription"
msgid "Capable of complex distillation and refining processes.\r\nHead Lift: 10 m\r\n(Allows fluids to be transported 10 meters upwards.)\r\n\r\nContains both Conveyor Belt and Pipeline inputs and output ports.\r\n\r\nFluid Output: The first fluid output port is at the top.\r\nSolid Output: The first solid output port is on the right."
msgstr "Capable of complex distillation and refining processes.\r\nHead Lift: 10 m\r\n(Allows fluids to be transported 10 meters upwards.)\r\n\r\nContains both Conveyor Belt and Pipeline inputs and output ports.\r\n\r\nFluid Output: The first fluid output port is at the top.\r\nSolid Output: The first solid output port is on the right."

