msgctxt "ST_Klib,Desc_PackagedAir.Desc_PackagedAir_C.mDescription"
msgid "Air, packaged for alternative transport."
msgstr "대체 운송을 위해 포장된 공기."

msgctxt "ST_Klib,Desc_BeltDriveMk4.Desc_BeltDriveMk4_C.mDisplayName"
msgid "AlClad Belt Drive"
msgstr "알클래드 벨트 드라이브"

msgctxt "ST_Klib,Res_LiquidBioWater.Res_LiquidBioWater_C.mAbbreviatedDisplayName"
msgid "Algae"
msgstr "조류"

msgctxt "ST_Klib,Res_LiquidBioWater.Res_LiquidBioWater_C.mDisplayName"
msgid "Algal Mass"
