msgctxt "StringTable_Categorys,MasterSorting"
msgid "Master Sorting"
msgstr "主排序"

msgid "Melting Point: 1000°C\\r\\n\\r\\nCaterium in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：1000°C\\r\\n\\r\\n液态钦金，适用于批量铸造锭或其他部件。"

msgid "Melting Point: 1084°C\\r\\n\\r\\nCopper in liquid form, useful for bulk casting ingots or other parts, as well as making Brass."
msgstr "熔点：1084°C\\r\\n\\r\\n液态铜，适用于批量铸造锭或其他部件，以及制造黄铜。"

msgid "Melting Point: 1160°C, Carbon Content: 3.80 %\\r\\n\\r\\nGrey Cast Iron in liquid form, useful for bulk casting ingots or other parts, as well as making steel."
msgstr "熔点：1160°C，碳含量：3.80%%\\r\\n\\r\\n液态灰铸铁，适用于批量铸造锭或其他部件，以及制造钢。"

msgid "Melting Point: 1380°C, Carbon Content: 0.85 %\\r\\n\\r\\nLiquid Steel. When cooled slowly, tough and ductile Pearlite is formed.\\r\\nWhen cooled quickly, hard and brittle Martensite is formed."
msgstr "熔点：1380°C，碳含量：0.85%%\\r\\n\\r\\n液态钢。缓慢冷却时形成坚韧有韧性的珠光体。\\r\\n快速冷却时形成硬而脆的马氏体。"

msgid "Melting Point: 1390°C\\r\\n\\r\\nMagnitar™ is FICSIT's internally developed iron-nickel-cobalt (Fernico) alloy.\\r\\nIt is ferromagnetic and can be processed into permanent magnets or magnetic cores."
msgstr "熔点：1390°C\\r\\n\\r\\n磁星铁™是FICSIT内部开发的铁镍钴合金。\\r\\n具有铁磁性，可加工成永磁体或磁芯。"

msgid "Melting Point: 1453°C\\r\\n\\r\\nNickel in liquid form, mainly used to produce magnetic alloys. Requires additional fuels to be molten down in a Flexible Blast Furnace."
msgstr "熔点：1453°C\\r\\n\\r\\n液态镍，主要用于生产磁性合金。需要在柔性高炉中添加额外燃料熔化。"

msgid "Melting Point: 1495°C\\r\\n\\r\\nCobalt in liquid form, useful for bulk casting ingots or other parts. Requires additional fuels to be molten down in a Flexible Blast Furnace."
msgstr "熔点：1495°C\\r\\n\\r\\n液态钴，适用于批量铸造锭或其他部件。需要在柔性高炉中添加额外燃料熔化。"

msgid "Melting Point: 220°C\\r\\n\\r\\nSolder in liquid form, either to be used directly or cast into Solder Wire and Solder Rods."
msgstr "熔点：220°C\\r\\n\\r\\n液态焊料，可直接使用或铸造成焊线和焊条。"

msgid "Melting Point: 232°C\\r\\n\\r\\nTin in liquid form, useful for bulk casting ingots or other parts.\\r\\nMelting it in a Flexible Blast Furance is energy inefficient."
msgstr "熔点：232°C\\r\\n\\r\\n液态锡，适用于批量铸造锭或其他部件。\\r\\n在柔性高炉中熔化能效较低。"

msgid "Melting Point: 328°C\\r\\n\\r\\nLead in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：328°C\\r\\n\\r\\n液态铅，适用于批量铸造锭或其他部件。"

msgid "Melting Point: 419°C\\r\\n\\r\\nZinc in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：419°C\\r\\n\\r\\n液态锌，适用于批量铸造锭或其他部件。"

msgid "Melting Point: 650°C\\r\\n\\r\\nMagnesium in liquid form, useful for bulk casting ingots or other parts.\\r\\nWARNING: Highly combustible!"
msgstr "熔点：650°C\\r\\n\\r\\n液态镁，适用于批量铸造锭或其他部件。\\r\\n警告：高度易燃！"

msgid "Melting Point: 660°C\\r\\n\\r\\nPure Aluminum in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：660°C\\r\\n\\r\\n纯液态铝，适用于批量铸造锭或其他部件。"

msgid "Melting Point: 930°C\\r\\n\\r\\nBrass in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：930°C\\r\\n\\r\\n液态黄铜，适用于批量铸造锭或其他部件。"

msgid "Melting Point: 950°C\\r\\n\\r\\nBronze in liquid form, useful for bulk casting ingots or other parts."
msgstr "熔点：950°C\\r\\n\\r\\n液态青铜，适用于批量铸造锭或其他部件。"

