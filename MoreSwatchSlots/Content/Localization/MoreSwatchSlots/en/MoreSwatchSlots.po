msgctxt "ST_MoreSwatchSlots,ResourceSink_MSS_SwatchSlots.ResourceSink_MSS_SwatchSlots_C.mDescription"
msgid "Add more swatch slots to the customizer"
msgstr "Add more swatch slots to the customizer"

msgid "Give your factory a new paint job!\\r\\n\\r\\nWarning: Changing this Swatch will apply the change to all buildings currently using it.\\r\\n\\r\\nAdded by More Swatch Slots\\r\\n\\r\\nNote: after removing this mod the color slots will not disappear! So the colors will stay."
msgstr "Give your factory a new paint job!\\r\\n\\r\\nWarning: Changing this Swatch will apply the change to all buildings currently using it.\\r\\n\\r\\nAdded by More Swatch Slots\\r\\n\\r\\nNote: after removing this mod the color slots will not disappear! So the colors will stay."

